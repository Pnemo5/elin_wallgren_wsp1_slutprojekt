<form action="/books" method="post">
    <label>Titel <input type="text" name="book_title" value=<%= @book["title"]%>> </label>
    <label>Författare <input type="text" name="book_author" value=<%= @book["author"]%>> </label>

    <label>Antal sidor <input type="number" name="book_pages" min="1" max="13095" value=<%= @book["pages"]%>> </label>
    <label>Betyg <input type="number" name="book_rating" min="1" max="5" value=<%= @book["rating"]%>> </label>

    <label>Recension <input type="text" name="book_review" value=<%= @book["review"]%>> </label>
    <label>Omslags-url <input type="text" name="cover_url" value=<%= @book["cover"]%>> </label>
    <input type="submit" value="Spara">
</form>